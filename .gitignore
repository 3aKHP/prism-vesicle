# Bun / Node
node_modules/
bun.lockb

# Build output (compiled binaries)
dist/
build/
coverage/
/prism-vesicle
/prism-vesicle.exe
/main
/main.exe

# Local environment
.env
.env.*
!.env.example

# Persistent Instructions: local dogfood VESICLE.md at the repo root.
# Root-anchored so legitimate examples/fixtures under subdirs are unaffected.
/VESICLE.md

# Runtime state
.vesicle/
logs/
*.log

# Durable artifact roots (runtime output, not source)
# Kept out of git so model/user-produced artifacts do not pollute history;
# the directory structure itself is preserved via .gitkeep stubs.
workspace/*
!workspace/.gitkeep
test_runs/*
!test_runs/.gitkeep
novels/*
!novels/.gitkeep
reports/*
!reports/.gitkeep
source_materials/*
!source_materials/.gitkeep

# Local non-public development notes
/dev/

# Generated test workspaces
tmp/
temp/
test-workspaces/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
