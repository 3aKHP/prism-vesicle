{
  "name": "prism-vesicle",
  "version": "1.0.0-alpha.1",
  "description": "Bun terminal host for Prism Engine prompt workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3aKHP/prism-vesicle.git"
  },
  "homepage": "https://github.com/3aKHP/prism-vesicle#readme",
  "bugs": {
    "url": "https://github.com/3aKHP/prism-vesicle/issues"
  },
  "keywords": [
    "bun",
    "tui",
    "prism",
    "ai"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "@babel/core": "7.29.7"
  },
  "files": [
    "assets/",
    "src/"
  ],
  "bin": {
    "vesicle": "./src/cli/main.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/main.ts",
    "doctor": "bun run src/cli/main.ts doctor",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "pack:check": "bun run scripts/check-npm-pack.ts",
    "pack:smoke": "bun run scripts/smoke-npm-package.ts",
    "build:exe": "bun run scripts/build-exe.ts",
    "build:assets": "bun run scripts/build-assets.ts"
  },
  "dependencies": {
    "@opentui/core": "0.4.3",
    "@opentui/keymap": "0.4.3",
    "@opentui/solid": "0.4.3",
    "diff": "9.0.0",
    "solid-js": "1.9.14",
    "web-tree-sitter": "0.25.10"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
