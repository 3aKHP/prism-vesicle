{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/3aKHP/Neural-Narratology/shared/rule-assets/schemas/detector-rules.schema.json",
  "title": "Detector Rules v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "module",
    "language",
    "rules"
  ],
  "properties": {
    "schema": {
      "const": "detector-rules/v1"
    },
    "module": {
      "$ref": "#/$defs/identifier"
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tier",
        "lang",
        "title",
        "severity",
        "maturity",
        "targets",
        "matcher",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "minLength": 1
        },
        "lang": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "maturity": {
          "enum": [
            "experimental",
            "stable"
          ]
        },
        "targets": {
          "$ref": "#/$defs/stringList"
        },
        "matcher": {
          "$ref": "#/$defs/matcher"
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "matcher": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "value",
            "unit"
          ],
          "properties": {
            "kind": {
              "enum": [
                "literal",
                "regex"
              ]
            },
            "value": {
              "type": "string",
              "minLength": 1
            },
            "unit": {
              "enum": [
                "candidate",
                "paragraph",
                "sentence"
              ]
            },
            "flags": {
              "type": "string",
              "pattern": "^[dimsuv]*$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "unit",
            "metric"
          ],
          "properties": {
            "kind": {
              "const": "metric"
            },
            "unit": {
              "enum": [
                "candidate",
                "paragraph",
                "sentence"
              ]
            },
            "metric": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "signal",
                "operator",
                "threshold"
              ],
              "properties": {
                "signal": {
                  "enum": [
                    "em_dash_per_100_chars",
                    "micro_action_per_1000_chars",
                    "action_list_verbs_per_paragraph",
                    "cliche_per_1000_chars",
                    "metaphor_markers_per_1000_chars",
                    "reasoning_chain_per_1000_chars",
                    "abstract_summary_per_1000_chars"
                  ]
                },
                "operator": {
                  "enum": [
                    "gte",
                    "gt",
                    "lte",
                    "lt"
                  ]
                },
                "threshold": {
                  "type": "number"
                },
                "minimumMatches": {
                  "type": "integer",
                  "minimum": 1
                },
                "minimumCoreMatches": {
                  "type": "integer",
                  "minimum": 1
                },
                "minimumBuckets": {
                  "type": "integer",
                  "minimum": 1
                },
                "minimumSeparators": {
                  "type": "integer",
                  "minimum": 1
                },
                "excludeDialogue": {
                  "type": "boolean"
                },
                "patterns": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "id",
                      "value"
                    ],
                    "properties": {
                      "id": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9-]*$"
                      },
                      "value": {
                        "type": "string",
                        "minLength": 1
                      },
                      "flags": {
                        "type": "string",
                        "pattern": "^[dimsuv]*$"
                      },
                      "core": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "signal": {
                        "not": {
                          "const": "em_dash_per_100_chars"
                        }
                      }
                    },
                    "required": [
                      "signal"
                    ]
                  },
                  "then": {
                    "required": [
                      "minimumMatches",
                      "excludeDialogue",
                      "patterns"
                    ],
                    "properties": {
                      "excludeDialogue": {
                        "const": true
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "signal": {
                        "const": "reasoning_chain_per_1000_chars"
                      }
                    },
                    "required": [
                      "signal"
                    ]
                  },
                  "then": {
                    "required": [
                      "minimumCoreMatches",
                      "minimumBuckets"
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "signal": {
                        "const": "action_list_verbs_per_paragraph"
                      }
                    },
                    "required": [
                      "signal"
                    ]
                  },
                  "then": {
                    "required": [
                      "minimumSeparators"
                    ]
                  }
                }
              ]
            }
          }
        }
      ]
    }
  }
}
