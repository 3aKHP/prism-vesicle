{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/3aKHP/Neural-Narratology/shared/rule-assets/schemas/judge-rules.schema.json",
  "title": "Judge Rules v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "module",
    "language",
    "rules"
  ],
  "properties": {
    "schema": {
      "const": "judge-rules/v1"
    },
    "module": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "maturity",
          "targets",
          "source",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "maturity": {
            "enum": [
              "experimental",
              "stable"
            ]
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mode",
              "minCodePoints",
              "maxCodePoints"
            ],
            "properties": {
              "mode": {
                "const": "exact-substring"
              },
              "minCodePoints": {
                "type": "integer",
                "minimum": 1
              },
              "maxCodePoints": {
                "type": "integer",
                "minimum": 1,
                "maximum": 512
              }
            }
          }
        }
      }
    }
  }
}
