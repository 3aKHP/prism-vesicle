{
  "schema": "detector-rules/v1",
  "module": "anti-ai-flavor",
  "language": "zh-CN",
  "rules": [
    {
      "id": "zh-f0-air-thick-with",
      "tier": "F0",
      "lang": "zh-CN",
      "title": "「空气中弥漫着」环境套话",
      "severity": "tier1",
      "maturity": "stable",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "literal",
        "value": "空气中弥漫着",
        "unit": "candidate"
      },
      "source": "self"
    },
    {
      "id": "zh-f0-meaningless-filler",
      "tier": "F0",
      "lang": "zh-CN",
      "title": "无意义装饰短句",
      "severity": "tier2",
      "maturity": "stable",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "regex",
        "value": "^(就这样(?:[，,][^。！？!?]{0,12})?|于是[^。！？!?]{0,8}了)[。！!？?]?$",
        "unit": "sentence",
        "flags": "u"
      },
      "source": "self"
    },
    {
      "id": "zh-f0-essay-register-connectors",
      "tier": "F0",
      "lang": "zh-CN",
      "title": "论说文语域连接词渗入叙事",
      "severity": "tier2",
      "maturity": "stable",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "regex",
        "value": "(总而言之|不得不说|值得一提的是|与此同时[，,])",
        "unit": "sentence",
        "flags": "u"
      },
      "source": "self"
    },
    {
      "id": "zh-f1-not-x-but-y",
      "tier": "F1",
      "lang": "zh-CN",
      "title": "「不是……而是……」对比句式",
      "severity": "tier1",
      "maturity": "stable",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "regex",
        "value": "不是[^。！？!?]{1,30}而是",
        "unit": "sentence",
        "flags": "u"
      },
      "source": "self"
    },
    {
      "id": "zh-f1-narrator-filler-before-quote",
      "tier": "F1",
      "lang": "zh-CN",
      "title": "引号前的旁白式停顿(\"她顿了一下,然后说——\")",
      "severity": "tier1",
      "maturity": "stable",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "regex",
        "value": "(顿了一下|沉默了一会儿)[,，]?然后说",
        "unit": "sentence",
        "flags": "u"
      },
      "source": "self"
    },
    {
      "id": "zh-f3-emdash-density",
      "tier": "F3",
      "lang": "zh-CN",
      "title": "破折号密度过高",
      "severity": "tier3",
      "maturity": "experimental",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "metric",
        "unit": "paragraph",
        "metric": {
          "signal": "em_dash_per_100_chars",
          "operator": "gte",
          "threshold": 2
        }
      },
      "source": "cn-antislop"
    },
    {
      "id": "zh-f3-micro-action-density",
      "tier": "F3",
      "lang": "zh-CN",
      "title": "微动作补语高密度复读",
      "severity": "tier3",
      "maturity": "experimental",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "metric",
        "unit": "candidate",
        "metric": {
          "signal": "micro_action_per_1000_chars",
          "operator": "gte",
          "threshold": 6,
          "minimumMatches": 5,
          "excludeDialogue": true,
          "patterns": [
            {
              "id": "light-action-complement",
              "value": "了(?:[一两三几半])?[下阵圈道声眼口气会]",
              "flags": "u"
            }
          ]
        }
      },
      "source": "oh-story-claudecode"
    },
    {
      "id": "zh-f3-action-list-density",
      "tier": "F3",
      "lang": "zh-CN",
      "title": "同段动作清单过密",
      "severity": "tier3",
      "maturity": "experimental",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "metric",
        "unit": "paragraph",
        "metric": {
          "signal": "action_list_verbs_per_paragraph",
          "operator": "gte",
          "threshold": 5,
          "minimumMatches": 5,
          "minimumSeparators": 4,
          "excludeDialogue": true,
          "patterns": [
            {
              "id": "generic-action-verb",
              "value": "伸手|抬手|探手|拿起|拿过|取出|取过|掏出|摸出|抓起|攥住|握住|捏住|按住|推开|拉开|打开|关上|放下|递给|挑开|掀开|扯开|拧开|倒出|端起|转身|回头|抬头|低头|弯腰|俯身|走到|走向|坐下|站起|看向|看着|盯着|扫过",
              "flags": "u"
            }
          ]
        }
      },
      "source": "oh-story-claudecode"
    },
    {
      "id": "zh-f3-cliche-density",
      "tier": "F3",
      "lang": "zh-CN",
      "title": "高危叙事套词聚集",
      "severity": "tier3",
      "maturity": "experimental",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "metric",
        "unit": "candidate",
        "metric": {
          "signal": "cliche_per_1000_chars",
          "operator": "gte",
          "threshold": 12,
          "minimumMatches": 8,
          "excludeDialogue": true,
          "patterns": [
            {
              "id": "simile-connectors",
              "value": "仿佛|犹如|宛若|如同",
              "flags": "u"
            },
            {
              "id": "vague-quantity",
              "value": "一丝|一抹|些许|几分|隐约",
              "flags": "u"
            },
            {
              "id": "softened-motion",
              "value": "深吸一口气|缓缓|微微|轻轻|淡淡",
              "flags": "u"
            },
            {
              "id": "stock-body-detail",
              "value": "眼中闪过|嘴角勾起|眸光微微一闪|指节泛白|目光锐利|眼神锐利",
              "flags": "u"
            },
            {
              "id": "stock-inner-state",
              "value": "心中涌起一股|心头一震|心中一动|心下了然|心中暗道|心中一凛",
              "flags": "u"
            },
            {
              "id": "absolute-claim",
              "value": "不容置疑|不容置喙|不易察觉|显而易见|毫无疑问|不可否认",
              "flags": "u"
            },
            {
              "id": "flat-voice",
              "value": "声音不大[，,]?却带着|语气平静无波|平静无波|声音平直|听不出情绪",
              "flags": "u"
            },
            {
              "id": "vague-transition",
              "value": "不知何时|唾手可得|无声翻涌|沉默(?:在[^。！？!?\\n]{0,16})?蔓延|难以言说",
              "flags": "u"
            },
            {
              "id": "stock-atmosphere",
              "value": "散发着一股|冰冷的光|格外刺眼|深邃而冰冷",
              "flags": "u"
            }
          ]
        }
      },
      "source": "oh-story-claudecode"
    },
    {
      "id": "zh-f3-metaphor-density",
      "tier": "F3",
      "lang": "zh-CN",
      "title": "比喻标记成片复现",
      "severity": "tier3",
      "maturity": "experimental",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "metric",
        "unit": "candidate",
        "metric": {
          "signal": "metaphor_markers_per_1000_chars",
          "operator": "gte",
          "threshold": 3,
          "minimumMatches": 7,
          "excludeDialogue": true,
          "patterns": [
            {
              "id": "explicit-simile-marker",
              "value": "好像|像是|仿佛|宛如|如同|犹如|(?<![不头图画影录摄肖])像(?![头像素])",
              "flags": "u"
            },
            {
              "id": "material-like-phrase",
              "value": "(?:死|水|冰|火|潮水|石头|木头|机器|纸|铁|鬼|死人|刀|针|网|墙)一样",
              "flags": "u"
            }
          ]
        }
      },
      "source": "oh-story-claudecode"
    },
    {
      "id": "zh-f3-reasoning-chain-density",
      "tier": "F3",
      "lang": "zh-CN",
      "title": "解释与判断链过密",
      "severity": "tier3",
      "maturity": "experimental",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "metric",
        "unit": "candidate",
        "metric": {
          "signal": "reasoning_chain_per_1000_chars",
          "operator": "gte",
          "threshold": 18,
          "minimumMatches": 8,
          "minimumCoreMatches": 4,
          "minimumBuckets": 2,
          "excludeDialogue": true,
          "patterns": [
            {
              "id": "mental-assertion",
              "value": "(?<![不没未无])(?:他|她|我)?(?:知道|明白|意识到|清楚|判断|确认|分析)",
              "flags": "u",
              "core": true
            },
            {
              "id": "explanatory-connector",
              "value": "这意味着|也就是说|换句话说|真正的问题(?:在于)?|问题在于|关键在于|在这种情况下|按照这个逻辑|只有这样|想到这里",
              "flags": "u",
              "core": true
            },
            {
              "id": "modal-consequence",
              "value": "(?:(?<!不)(?:必须|需要|应该|只要|就会|可能|可以|能够|无法)|不能)[^。！？!?\\n]{0,16}(?:判断|确认|承担|维持|稳住|控制|扩大|失控|带来|造成|理解|默认|回家|进门|核对|筛选|减少|建立|风险|结果|秩序|责任)",
              "flags": "u",
              "core": true
            },
            {
              "id": "abstract-domain-term",
              "value": "任务|条件|风险|来源|逻辑|局面|结果|责任|秩序|规则|信息不足|决策能力",
              "flags": "u"
            }
          ]
        }
      },
      "source": "oh-story-claudecode"
    },
    {
      "id": "zh-f3-abstract-summary-density",
      "tier": "F3",
      "lang": "zh-CN",
      "title": "抽象总结模板复读",
      "severity": "tier3",
      "maturity": "experimental",
      "targets": [
        "narrative-prose"
      ],
      "matcher": {
        "kind": "metric",
        "unit": "candidate",
        "metric": {
          "signal": "abstract_summary_per_1000_chars",
          "operator": "gte",
          "threshold": 4,
          "minimumMatches": 3,
          "excludeDialogue": true,
          "patterns": [
            {
              "id": "realization-summary",
              "value": "这一刻[，,]?[^\\n。！？!?]{0,24}(?:终于|才)(?:明白|意识到)",
              "flags": "u"
            },
            {
              "id": "from-this-moment",
              "value": "从这一刻开始",
              "flags": "u"
            },
            {
              "id": "destiny-summary",
              "value": "(?:命运|宿命)[^\\n。！？!?]{0,28}(?:齿轮|棋局|獠牙|改写|推向|安排)",
              "flags": "u"
            },
            {
              "id": "arranged-board",
              "value": "早已[^\\n。！？!?]{0,8}(?:布好|安排好)[^\\n。！？!?]{0,8}(?:棋局|局)",
              "flags": "u"
            },
            {
              "id": "unprecedented-state",
              "value": "前所未有的(?:决意|清醒|勇气|力量|恐惧|平静|信念)",
              "flags": "u"
            },
            {
              "id": "only-just-begun",
              "value": "(?:反击|复仇|战争|较量|故事|命运)[^\\n。！？!?]{0,12}才刚刚开始",
              "flags": "u"
            },
            {
              "id": "new-beginning",
              "value": "新的开始|全新的开始",
              "flags": "u"
            }
          ]
        }
      },
      "source": "oh-story-claudecode"
    }
  ]
}
